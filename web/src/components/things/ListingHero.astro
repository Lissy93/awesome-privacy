---
import type { Section, Service } from '../../types/Service';
import { slugify } from '@utils/fetch-data';
import { parseMarkdown, formatLink } from '@utils/parse-markdown';
import FontAwesome from '@components/form/FontAwesome.svelte';
import SaveListing from '@components/things/SaveListing.svelte';
import ServiceIcon from '@components/things/ServiceIcon.astro';

interface Props {
	service: Service;
	parentSection: Section;
	categoryName: string;
	privacyPolicyLink: string | null;
}

const { service, parentSection, categoryName, privacyPolicyLink } = Astro.props;
const {
	name,
	description,
	url,
	github,
	tosdrId,
	iosApp,
	androidApp,
	discordInvite,
	subreddit,
	icon,
	followWith,
	links,
	securityAudited,
	openSource,
	acceptsCrypto,
} = service;

const catSlug = slugify(categoryName);
const secSlug = slugify(parentSection.name);

const otherServices = parentSection.services.filter(
	(s: Service) => s.name !== name,
);

const infoLinks = [
	url && { label: 'Homepage', href: url, text: formatLink(url) },
	github && {
		label: 'GitHub',
		href: `https://github.com/${github}`,
		text: `github.com/${github}`,
	},
	tosdrId && {
		label: 'Privacy',
		href: privacyPolicyLink,
		text: formatLink(privacyPolicyLink || ''),
	},
	iosApp && { label: 'iOS App', href: iosApp, text: formatLink(iosApp) },
	androidApp && {
		label: 'Android App',
		href: `https://play.google.com/store/apps/details?id=${androidApp}`,
		text: `play.google.com/.../${androidApp}`,
	},
	discordInvite && {
		label: 'Discord',
		href: `https://discord.com/invite/${discordInvite}`,
		text: discordInvite,
	},
	subreddit && {
		label: 'Subreddit',
		href: `https://reddit.com/r/${subreddit}`,
		text: `r/${subreddit}`,
	},
	url && {
		label: 'Web info',
		href: `https://web-check.xyz/check/${formatLink(url)}`,
		text: `web-check.xyz/check/${formatLink(url).split('/')[0]}`,
	},
	...(links || []).map((link) => ({
		label: link.title,
		href: link.url,
		text: link.url,
	})),
].filter(Boolean) as { label: string; href: string | null; text: string }[];

const highlights = [
	securityAudited && {
		icon: 'securityAudited',
		text: 'Security Audited',
		cls: 'great',
		title: `${name} has been security audited by an accredited auditor, with results published publicly`,
	},
	acceptsCrypto && {
		icon: 'cryptoAccepted',
		text: 'Crypto Payments Accepted',
		cls: 'great',
		title: `${name} accepts anonymous payment methods`,
	},
	securityAudited === false && {
		icon: 'notSecurityAudited',
		text: 'No Security Audit',
		cls: 'warning',
		title: `${name} has not been audited`,
	},
	openSource === false && {
		icon: 'closedSource',
		text: 'Not Open Source',
		cls: 'warning',
		title: `${name} is not open source`,
	},
	(openSource || (github && openSource !== false)) && {
		icon: 'openSource',
		text: 'Open Source',
		cls: 'great',
		title: `${name} is open source`,
	},
].filter(Boolean) as {
	icon: string;
	text: string;
	cls: string;
	title: string;
}[];
---

<section class="hero-section">
	<div class="service-head">
		<h2>{name}</h2>
		<span class="url-wrap">
			<a class="service-url" href={url}>{formatLink(url)}</a>
			<span class="follow-with">{followWith}</span>
		</span>
	</div>
	<div class="breadcrumbs">
		<span>
			<a href="/">Awesome Privacy</a>
			➔ <a href={`/${catSlug}`}>{categoryName}</a>
			➔ <a href={`/${catSlug}/${secSlug}`}>{parentSection.name}</a>
			➔ <a href={`/${catSlug}/${secSlug}/${slugify(name)}`}>{name}</a>
		</span>
	</div>
	<div class="save-listing">
		<SaveListing
			client:visible
			categoryName={categoryName}
			sectionName={parentSection.name}
			serviceName={name}
			showLabel={true}
		/>
	</div>
	<div class="intro">
		<ServiceIcon name={name} url={url} icon={icon} size={60} />
		<div>
			<p class="description" set:html={parseMarkdown(description)} />
			<ul>
				{
					infoLinks.map((link) => (
						<li>
							<b>{link.label}:</b>
							<a href={link.href} target="_blank" rel="noopener noreferrer">
								{link.text}
							</a>
						</li>
					))
				}
			</ul>
			<div class="related">
				{
					(parentSection.alternativeTo || []).length > 0 && (
						<div class="related-group">
							<h4 class="avoid">
								<FontAwesome iconName="faceBad" /> Avoid
							</h4>
							<ul>
								{(parentSection.alternativeTo || []).map((alt: string) => (
									<li>
										<span>{alt}</span>
									</li>
								))}
							</ul>
						</div>
					)
				}
				{
					otherServices.length > 0 && (
						<div class="related-group">
							<h4 class="consider">
								<FontAwesome iconName="faceGood" /> Also Consider
							</h4>
							<ul>
								{otherServices.map((s: Service) => (
									<li>
										<a href={`/${catSlug}/${secSlug}/${slugify(s.name)}`}>
											{s.name}
										</a>
									</li>
								))}
							</ul>
						</div>
					)
				}
			</div>
		</div>
	</div>
	<div class="highlights">
		{
			highlights.map((h) => (
				<span class={`meta-item ${h.cls}`} title={h.title}>
					<FontAwesome iconName={h.icon} /> {h.text}
				</span>
			))
		}
	</div>
</section>

<style lang="scss">
	.hero-section {
		margin: var(--space-md) 0 var(--space-2xl) 0;
		padding: var(--space-md);
		min-height: 8rem;
		position: relative;
		border: var(--border-heavy);
		box-shadow: var(--shadow-lg);
		background: var(--accent-fg);
	}

	.service-head {
		h2 {
			font-size: var(--text-4xl);
			margin: 0;
			@media (max-width: 768px) {
				text-align: center;
			}
		}
		.url-wrap {
			display: flex;
			align-items: center;
			gap: var(--space-sm);
			a {
				font-size: var(--text-md);
			}
			.follow-with {
				font-style: italic;
				opacity: var(--opacity-muted);
			}
			@media (max-width: 768px) {
				flex-direction: column;
			}
		}
	}

	.save-listing {
		position: absolute;
		top: var(--space-xl);
		right: var(--space-md);
	}

	.intro {
		font-size: var(--text-md);
		font-style: italic;
		opacity: 0.9;
		display: flex;
		gap: var(--space-sm);
		@media (max-width: 768px) {
			flex-direction: column;
		}
		:global(.service-icon-wrap) {
			border-radius: var(--curve-md);
			margin-top: var(--space-md);
			@media (max-width: 768px) {
				margin: var(--space-md) auto 0 auto;
			}
		}
		ul {
			padding-left: var(--space-md);
			list-style: circle;
			font-style: normal;
			font-size: var(--text-base);
			margin-top: 0;
			b {
				font-size: var(--text-base);
				font-weight: 400;
				min-width: 100px;
				display: inline-block;
				@media (max-width: 768px) {
					width: auto;
					display: block;
				}
			}
		}
	}

	.related {
		display: flex;
		gap: var(--space-lg);
		flex-wrap: wrap;
		margin: var(--space-md) 0;
		.related-group {
			h4 {
				font-size: var(--text-sm);
				font-family: var(--font-subtitle);
				text-transform: uppercase;
				opacity: var(--opacity-muted);
				margin: 0 0 var(--space-xs) 0;
				display: flex;
				align-items: center;
				gap: var(--space-xs);
				:global(svg) {
					width: var(--text-sm);
					height: var(--text-sm);
				}
				&.avoid :global(svg) {
					color: var(--danger);
				}
				&.consider :global(svg) {
					color: var(--success-muted);
				}
			}
			ul {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-wrap: wrap;
				gap: var(--space-xs);
				li {
					font-size: var(--text-sm);
					padding: var(--space-xs) var(--space-sm);
					border: var(--border-light);
					border-radius: var(--curve-pill);
					a {
						color: var(--foreground);
						text-decoration: none;
						&:hover {
							color: var(--accent);
						}
					}
					span {
						opacity: var(--opacity-soft);
					}
				}
			}
		}
	}

	.highlights {
		display: flex;
		gap: var(--space-md);
		flex-wrap: wrap;
		align-items: center;
		justify-content: end;
		.meta-item {
			display: flex;
			align-items: center;
			gap: var(--space-xs);
			opacity: var(--opacity-muted);
			font-size: var(--text-sm);
			padding: var(--space-sm) 0;
			:global(svg) {
				width: var(--text-md);
				height: var(--text-md);
			}
		}
		.warning {
			color: var(--danger);
			:global(svg) {
				color: var(--danger);
			}
		}
		.great {
			color: var(--success-muted);
			:global(svg) {
				color: var(--success-muted);
			}
		}
	}
</style>
