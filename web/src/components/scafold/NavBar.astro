---
import FontAwesome from '@components/form/FontAwesome.svelte';
import ThemeSwitcher from '@components/form/ThemeSwitcher.svelte';

const navLinks = [
	{ label: 'View All', href: '/all' },
	{ label: 'Search', href: '/search' },
	{ label: 'Changelog', href: '/changelog' },
	{ label: 'API', href: '/api' },
	{ label: 'Saved', href: '/inventory', id: 'saved-nav-link', hidden: true },
	{ label: 'About', href: '/about' },
	{
		label: 'GitHub',
		href: 'https://github.com/lissy93/awesome-privacy',
		external: true,
	},
];
---

<header class="site-header">
	<a href="/" class="logo" aria-label="Awesome Privacy - Home">
		<FontAwesome iconName="logo" />
		<span>Awesome Privacy</span>
	</a>
	<button
		class="burger"
		type="button"
		aria-label="Toggle navigation menu"
		aria-expanded="false"
		aria-controls="nav-menu"
	>
		<span class="burger-line"></span><span class="burger-line"></span><span
			class="burger-line"></span>
	</button>
	<nav id="nav-menu" aria-label="Main navigation">
		{
			navLinks.map((link) => (
				<a
					href={link.href}
					class="nav-link"
					id={link.id}
					style={link.hidden ? 'display:none' : undefined}
					target={link.external ? '_blank' : undefined}
					rel={link.external ? 'noopener noreferrer' : undefined}
				>
					{link.label}
					{link.external && <span class="sr-only">(opens in new tab)</span>}
				</a>
			))
		}
		<div class="theme-switcher">
			<ThemeSwitcher client:load />
		</div>
	</nav>
</header>

<script>
	document.addEventListener('astro:page-load', () => {
		const burger = document.querySelector('.burger');
		const nav = document.getElementById('nav-menu');
		if (!burger || !nav) return;

		const close = () => {
			nav.classList.remove('open');
			burger.classList.remove('is-active');
			burger.setAttribute('aria-expanded', 'false');
		};

		burger.addEventListener('click', () => {
			const isOpen = nav.classList.toggle('open');
			burger.classList.toggle('is-active', isOpen);
			burger.setAttribute('aria-expanded', String(isOpen));
		});

		nav.querySelectorAll('.nav-link').forEach((link) => {
			link.addEventListener('click', close);
		});

		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && nav.classList.contains('open')) {
				close();
				(burger as HTMLElement).focus();
			}
		});

		// Show "Saved" link if user has saved items
		try {
			const saved = JSON.parse(localStorage.getItem('savedServices') || '[]');
			const el = document.getElementById('saved-nav-link');
			if (el && saved.length > 0) el.style.display = '';
		} catch {
			/* ignore parse errors */
		}
	});
</script>

<style lang="scss">
	.site-header {
		background: var(--accent-fg);
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		align-items: center;
		border-bottom: 2px solid var(--accent-3);
		position: relative;

		.logo {
			text-decoration: none;
			display: flex;
			align-items: center;
			padding: 0 var(--space-sm);
			span {
				font-size: 2.4rem;
				padding: 0 var(--space-md);
				color: var(--foreground);
				font-family: var(--font-subtitle);
				font-weight: bold;
			}
			:global(svg) {
				width: 2.5rem;
				height: 2.5rem;
				color: var(--accent-3);
				transition: var(--transition-normal);
			}
			&:hover :global(svg) {
				color: var(--accent);
				transform: scale(1.05);
			}
		}

		.burger {
			display: none;
			flex-direction: column;
			justify-content: center;
			gap: 5px;
			padding: var(--space-sm);
			margin-right: var(--space-sm);
			background: none;
			border: none;
			cursor: pointer;
			.burger-line {
				display: block;
				width: 24px;
				height: 2px;
				background: var(--foreground);
				transition: var(--transition-fast);
			}
			&.is-active .burger-line {
				&:nth-child(1) {
					transform: translateY(7px) rotate(45deg);
				}
				&:nth-child(2) {
					opacity: 0;
				}
				&:nth-child(3) {
					transform: translateY(-7px) rotate(-45deg);
				}
			}
		}

		nav {
			display: flex;
			align-items: center;
			height: 3rem;
			.nav-link {
				padding: var(--space-md);
				font-size: var(--text-md);
				font-family: var(--font-subtitle);
				font-weight: bold;
				color: var(--foreground);
				text-decoration: none;
				transition:
					background 0.3s ease-in-out,
					color 0.3s ease-in-out;
				&:hover {
					color: var(--accent-fg);
					&:nth-child(4n + 1) {
						background: var(--accent);
					}
					&:nth-child(4n + 2) {
						background: var(--accent-2);
						color: var(--foreground);
					}
					&:nth-child(4n + 3) {
						background: var(--accent-3);
					}
					&:nth-child(4n + 4) {
						background: var(--accent-4);
						color: var(--foreground);
					}
				}
			}
			.theme-switcher {
				transform: scale(0.7);
				margin: 0.2rem auto;
			}
		}

		@media (max-width: 1100px) {
			nav .nav-link {
				padding: var(--space-sm) var(--space-sm);
				font-size: var(--text-base);
			}
			.logo {
				span {
					font-size: var(--text-3xl);
				}
			}
		}

		@media (max-width: 768px) {
			flex-wrap: wrap;
			.logo {
				margin: 0 auto;
				:global(svg) {
					@media (max-width: 428px) {
						display: none;
					}
				}
				span {
					@media (max-width: 428px) {
						font-size: var(--text-2xl);
					}
				}
			}
			.burger {
				display: flex;
			}
			nav {
				display: none;
				flex-direction: column;
				width: 100%;
				position: absolute;
				top: 100%;
				left: 0;
				background: var(--accent-fg);
				border-bottom: 2px solid var(--accent-3);
				z-index: 100;
				height: auto;
				&.open {
					display: flex;
				}
				.nav-link {
					width: 100%;
					text-align: center;
					padding: var(--space-md) var(--space-lg);
					border-bottom: 1px solid var(--accent-3-translucent);
				}
				.theme-switcher {
					display: none;
				}
			}
		}
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		border: 0;
	}
</style>
