---
import Layout from '@layouts/Layout.astro';
import Main from '@components/scafold/MainCard.astro';
import ChangelogTimeline from '@components/things/ChangelogTimeline.svelte';
import { fetchChangelog } from '@utils/fetch-changelog';

const changelog = await fetchChangelog();
---

<Layout title="Changelog | Awesome Privacy" description="A transparent log of all additions, removals, and amendments to the Awesome Privacy list.">
	<div class="changelog-page">
		<Main>
			<h2>Changelog</h2>
			<p>
				All data in awesome-privacy is managed via Git,
				so that we have a complete and transparent changelog
				of exactly what was added when and by whom.
			</p>
			{changelog.entries.length > 0 ? (
				<ChangelogTimeline client:load entries={changelog.entries} rejections={changelog.rejections || []} />
			) : (
				<p class="fallback">Changelog data is currently unavailable.</p>
			)}
		</Main>
	</div>
</Layout>

<style lang="scss">
	h2 {
		font-size: var(--text-3xl);
		margin: 0;
	}
	p {
		font-size: var(--text-md);
		margin: 0 0 var(--space-md) 0;
	}
	.fallback {
		text-align: center;
		opacity: var(--opacity-muted);
	}
</style>
